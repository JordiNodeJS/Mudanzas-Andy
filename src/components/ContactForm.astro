---
interface Props {
  variant?: "sticky" | "inline";
}

const { variant = "sticky" } = Astro.props as Props;
import ContactFormSticky from "./ContactFormSticky.astro";
import ContactFormInline from "./ContactFormInline.astro";
---

{variant === "sticky" ? <ContactFormSticky /> : <ContactFormInline />}

<!-- External small script to handle form actions -->
<script src="/js/contact-form.js" defer></script>
