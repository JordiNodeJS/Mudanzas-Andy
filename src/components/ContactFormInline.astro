---

---

<div
  class="bg-[#FBF3E8] border border-[#F3E8D8] rounded-xl shadow-lg p-6 max-w-2xl w-full"
>
  <h3 class="text-lg font-bold text-[#264e70] mb-2">Solicita tu presupuesto</h3>
  <p class="text-sm text-gray-600 mb-4">
    Rellena tus datos y te contactamos por WhatsApp en menos de 10 minutos.
  </p>
  <form id="inlineBudgetForm" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <input
      type="text"
      name="name"
      id="name-inline"
      placeholder="Tu nombre"
      class="px-4 py-2 rounded-lg border-2 border-gray-200 focus:border-[#679186] focus:outline-none"
    />
    <input
      type="email"
      name="email"
      id="email-inline"
      placeholder="tu@email.com"
      required
      class="px-4 py-2 rounded-lg border-2 border-gray-200 focus:border-[#679186] focus:outline-none"
    />
    <input
      type="tel"
      name="phone"
      id="phone-inline"
      placeholder="640 50 60 84"
      class="px-4 py-2 rounded-lg border-2 border-gray-200 focus:border-[#679186] focus:outline-none"
    />
    <select
      name="service"
      id="service-inline"
      class="px-4 py-2 rounded-lg border-2 border-gray-200 focus:border-[#679186] focus:outline-none"
    >
      <option value="">Tipo de servicio</option>
      <option value="local">Mudanza local</option>
      <option value="nacional">Mudanza nacional</option>
      <option value="transporte">Transporte puntual</option>
    </select>
    <textarea
      name="message"
      id="message-inline"
      rows="3"
      placeholder="Comentarios adicionales"
      class="sm:col-span-2 px-4 py-2 rounded-lg border-2 border-gray-200 focus:border-[#679186] focus:outline-none"
    ></textarea>
    <div class="sm:col-span-2 flex items-center justify-between gap-3">
      <button
        type="submit"
        class="bg-[#679186] hover:bg-[#5a7a6f] text-white font-bold py-2 px-4 rounded-lg"
        >Enviar y recibir presupuesto</button
      >
      <a
        href="https://wa.me/34640506084"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-[#264e70] font-semibold"
        >💬 Abrir WhatsApp</a
      >
    </div>
  </form>
</div>
