---
import ServiceCard from "../ui/ServiceCard.astro";
---

<section id="servicios" class="py-16 lg:py-24 relative overflow-hidden">
  <!-- Background with patterns and gradients -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-accent/5"
  >
  </div>

  <!-- Decorative background elements -->
  <div class="absolute inset-0 opacity-10">
    <!-- Geometric shapes for visual interest -->
    <div
      class="absolute top-20 right-10 w-32 h-32 bg-gradient-to-br from-accent to-secondary rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-20 left-10 w-48 h-48 bg-gradient-to-br from-secondary to-primary rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-gradient-to-br from-cream to-neutral rounded-full blur-3xl"
    >
    </div>
  </div>

  <!-- Pattern overlay -->
  <div
    class="absolute inset-0 opacity-5"
    style="background-image: radial-gradient(circle at 1px 1px, rgb(var(--color-secondary)) 1px, transparent 0); background-size: 20px 20px;"
  >
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <!-- Enhanced header section -->
    <div class="text-center mb-16 lg:mb-20">
      <div
        class="inline-flex items-center gap-2 bg-gradient-to-r from-accent/20 to-secondary/20 px-4 py-2 rounded-full mb-6"
      >
        <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"></span>
        <span
          class="text-secondary font-semibold text-sm uppercase tracking-wide"
          >Servicios Profesionales</span
        >
      </div>

      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-extrabold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent mb-6"
      >
        Nuestros Servicios de Mudanza
      </h2>
      <p
        class="text-lg lg:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed"
      >
        Especialistas en mudanzas profesionales con más de <strong
          class="text-secondary">14 años de experiencia</strong
        >. Tu tranquilidad es nuestra prioridad.
      </p>
    </div>

    <!-- Services grid with featured service -->
    <div class="max-w-7xl mx-auto">
      <!-- Featured service (Mudanzas Particulares) -->
      <div class="mb-12 lg:mb-16">
        <ServiceCard
          iconName="home"
          title="Mudanzas Particulares"
          description="Nuestro servicio estrella. Mudanzas de viviendas completas con máximo cuidado de tus pertenencias y atención personalizada."
          features={[
            "Embalaje profesional incluido con materiales de alta calidad",
            "Desmontaje y montaje completo de todos tus muebles",
            "Seguro de responsabilidad civil hasta 30.000€",
            "Equipo especializado en objetos frágiles y obras de arte",
            "Coordinador personal asignado para tu mudanza",
          ]}
          gradient="bg-gradient-to-br from-accent/30 to-[#fdebd3]/40 border-accent/50"
          featured={true}
          ctaText="¡Solicitar Presupuesto GRATIS!"
          badge="⭐ MÁS POPULAR"
        />
      </div>

      <!-- Regular services grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
      >
        <ServiceCard
          iconName="building"
          title="Mudanzas de Oficinas"
          description="Traslados empresariales eficientes con mínima interrupción de tu negocio"
          features={[
            "Planificación estratégica detallada",
            "Horarios flexibles (fines de semana)",
            "Manejo especializado de equipos IT",
            "Documentación y seguimiento completo",
          ]}
          gradient="bg-gradient-to-br from-secondary/20 to-neutral/30 border-secondary/40"
          ctaText="Consultar para Empresas"
        />

        <ServiceCard
          iconName="package"
          title="Embalaje Profesional"
          description="Servicio completo de embalaje con materiales de alta calidad"
          features={[
            "Cajas especializadas por tipo",
            "Protección para objetos frágiles",
            "Etiquetado y inventario digital",
            "Desembalaje en destino incluido",
          ]}
          gradient="bg-gradient-to-br from-[#fdebd3]/40 to-accent/20 border-[#fdebd3]/60"
          ctaText="Solicitar Embalaje"
        />

        <ServiceCard
          iconName="bolt"
          title="Mudanzas Express"
          description="Mudanzas urgentes realizadas en el mismo día"
          features={[
            "Disponibilidad 24/7",
            "Respuesta en menos de 2 horas",
            "Equipo de emergencia dedicado",
            "Máxima rapidez garantizada",
          ]}
          gradient="bg-gradient-to-br from-neutral/30 to-secondary/20 border-neutral/50"
          ctaText="¡Emergencia Ya!"
          badge="🚨 URGENTE"
        />

        <ServiceCard
          iconName="archive"
          title="Guardamuebles Seguro"
          description="Almacenamiento seguro temporal de tus pertenencias"
          features={[
            "Instalaciones vigiladas 24h",
            "Control de humedad y temperatura",
            "Acceso flexible cuando lo necesites",
            "Inventario digital con fotos",
          ]}
          gradient="bg-gradient-to-br from-accent/15 to-secondary/10 border-accent/40"
          ctaText="Ver Almacenamiento"
        />

        <ServiceCard
          iconName="globe"
          title="Mudanzas Nacionales"
          description="Mudanzas por toda España con seguimiento en tiempo real"
          features={[
            "Cobertura nacional completa",
            "Seguimiento GPS en tiempo real",
            "Coordinación entre ciudades",
            "Entrega en fecha confirmada",
          ]}
          gradient="bg-gradient-to-br from-primary/15 to-neutral/25 border-primary/30"
          ctaText="Cotizar Nacional"
        />

        <!-- New international service -->
        <ServiceCard
          iconName="truck"
          title="Mudanzas Internacionales"
          description="Traslados internacionales con gestión completa de documentación"
          features={[
            "Gestión aduanal incluida",
            "Red de partners internacionales",
            "Coordinación puerta a puerta",
            "Seguros internacionales",
          ]}
          gradient="bg-gradient-to-br from-secondary/20 to-primary/15 border-secondary/40"
          ctaText="Consultar Internacional"
          badge="🌍 GLOBAL"
        />
      </div>

      <!-- Bottom CTA section -->
      <div class="mt-16 lg:mt-20 text-center">
        <div
          class="bg-gradient-to-r from-accent/10 to-secondary/10 backdrop-blur-sm border border-secondary/20 rounded-2xl p-8 lg:p-12"
        >
          <h3 class="text-2xl lg:text-3xl font-bold text-primary mb-4">
            ¿Necesitas un servicio personalizado?
          </h3>
          <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
            Cada mudanza es única. Contactanos para crear una solución a medida
            para tus necesidades específicas.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-4 justify-center items-center"
          >
            <a
              href="https://wa.me/34640506084"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-gradient-to-r from-accent to-secondary text-white px-8 py-4 rounded-xl font-bold text-lg hover:from-secondary hover:to-accent transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl"
            >
              💬 WhatsApp: Consulta Personalizada
            </a>
            <a
              href="tel:+34933539792"
              class="bg-white border-2 border-secondary text-secondary px-8 py-4 rounded-xl font-bold text-lg hover:bg-secondary hover:text-white transition-all duration-300 transform hover:scale-105"
            >
              📞 Llamar: 933 53 97 92
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
