---
import WhatsAppButton from "../ui/WhatsAppButton.astro";
import PhoneButton from "../ui/PhoneButton.astro";
---

<section
  id="inicio"
  class="bg-gradient-hero hero-offset pb-16 lg:pb-20 flow-root relative overflow-hidden"
>
  <!-- Imagen de fondo con filtro para mejor contraste -->
  <div class="absolute inset-0 z-0">
    <img
      src="/camion/hero-fondo.jpg"
      alt="Fondo: Camión de mudanzas profesional"
      class="w-full h-full object-cover opacity-15"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-hero"></div>
  </div>

  <div class="container-responsive relative z-10 text-center">
    <div class="max-w-4xl mx-auto">
      <h1
        class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-primary mb-4 lg:mb-6 leading-tight drop-shadow-sm break-words hyphens-auto"
      >
        Mudanzas profesionales en Barcelona y España
      </h1>
      <h2
        class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-semibold text-secondary mb-6 lg:mb-8 drop-shadow-sm break-words hyphens-auto"
      >
        ¡Presupuesto GRATIS en 5 minutos por WhatsApp!
      </h2>

      <!-- CTAs principales -->
      <div
        class="flex flex-col sm:flex-row gap-3 lg:gap-4 justify-center items-center mb-10 lg:mb-12"
      >
        <WhatsAppButton
          phone="640506084"
          text="¡WhatsApp GRATIS!"
          variant="primary"
          fullWidth={true}
        />

        <PhoneButton
          phone="933 53 97 92"
          text="Llama: 933 53 97 92"
          variant="secondary"
          fullWidth={true}
        />
      </div>

      <!-- Destacados -->
      <div class="grid-cards max-w-3xl mx-auto">
        <div class="card card-glass">
          <div class="card-body text-center">
            <div class="text-2xl lg:text-3xl mb-2">⚡</div>
            <h3 class="text-sm lg:text-base font-bold text-primary mb-2">
              Respuesta Inmediata
            </h3>
            <p class="text-xs lg:text-sm text-secondary">
              Te respondemos en menos de 5 minutos
            </p>
          </div>
        </div>
        <div class="card card-glass">
          <div class="card-body text-center">
            <div class="text-2xl lg:text-3xl mb-2">💰</div>
            <h3 class="text-sm lg:text-base font-bold text-primary mb-2">
              Precio Cerrado
            </h3>
            <p class="text-xs lg:text-sm text-secondary">
              Sin sorpresas, precio final garantizado
            </p>
          </div>
        </div>
        <div class="card card-glass">
          <div class="card-body text-center">
            <div class="text-2xl lg:text-3xl mb-2">🚛</div>
            <h3 class="text-sm lg:text-base font-bold text-primary mb-2">
              +14 años experiencia
            </h3>
            <p class="text-xs lg:text-sm text-secondary">
              Miles de mudanzas exitosas
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
