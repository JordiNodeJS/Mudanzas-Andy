---
// No props needed for header
---

<header
  class="fixed top-0 w-full bg-[#264e70] text-white z-40 shadow-lg header-persistent"
>
  <div class="container mx-auto px-4 py-3">
    <div class="flex flex-wrap items-center justify-between">
      <!-- Logo y nombre -->
      <div class="flex items-center space-x-3">
        <!-- Animated truck logo -->
        <div class="relative overflow-hidden">
          <img
            src="/logos/logo-camion-transparent.png"
            alt="Mudanzas ANDY Logo"
            class="h-16 w-16 lg:h-20 lg:w-20 object-contain bg-transparent drop-shadow-sm self-center truck-logo"
            onerror="this.onerror=null;this.src='/logos/logo-camion-mudanzas.png';"
          />
        </div>
        <div>
          <h1 class="text-lg lg:text-xl font-bold text-[#FAE360]">
            Mudanzas ANDY
          </h1>
          <p class="text-xs text-[#bbd4ce] hidden sm:block">
            Tu mudanza, nuestra prioridad desde 2010
          </p>
        </div>
      </div>

      <!-- Menú de navegación desktop -->
      <nav class="hidden lg:flex items-center space-x-6">
        <a
          href="/"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Inicio
        </a>
        <a
          href="/servicios"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Servicios
        </a>
        <a
          href="/equipo"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Nuestro Equipo
        </a>
        <a
          href="/precios"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Precios
        </a>
        <a
          href="/testimonios"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Testimonios
        </a>
        <a
          href="/contacto"
          class="text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-sm"
        >
          Contacto
        </a>
      </nav>

      <!-- Botón menú móvil -->
      <button
        id="mobile-menu-button"
        class="lg:hidden flex items-center p-2 rounded-md text-[#bbd4ce] hover:text-[#FAE360] focus:outline-none focus:ring-2 focus:ring-[#FAE360] transition-colors duration-300"
        aria-label="Abrir menú de navegación"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <!-- Información de contacto -->
      <div
        class="hidden xl:flex flex-col sm:flex-row items-center space-y-2 sm:space-y-0 sm:space-x-4 lg:space-x-6"
      >
        <a
          href="tel:+34933539792"
          class="flex items-center space-x-2 text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300"
        >
          <span class="text-lg">📞</span>
          <span class="font-semibold text-sm lg:text-base">933 53 97 92</span>
        </a>

        <a
          href="mailto:mundanzas.andy@gmail.com"
          class="flex items-center space-x-2 text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300"
        >
          <!-- Use an inline SVG so the icon inherits the link color (currentColor) instead of a colored emoji -->
          <span class="text-lg" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="w-4 h-4 lg:w-5 lg:h-5"
              fill="currentColor"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
              ></path>
            </svg>
          </span>
          <span class="hidden lg:inline text-sm">mundanzas.andy@gmail.com</span>
          <span class="lg:hidden text-sm">Email</span>
        </a>
      </div>
    </div>

    <!-- Badge de atención 24/7 -->
    <div class="mt-2 text-center">
      <span
        class="inline-block bg-[#f9b4ab] text-[#264e70] px-3 lg:px-4 py-1 rounded-full text-xs lg:text-sm font-bold animate-bounce"
      >
        ¡Atención 24/7! Llámanos o escríbenos cuando quieras
      </span>
    </div>

    <!-- Menú móvil -->
    <nav
      id="mobile-menu"
      class="lg:hidden hidden w-full mt-4 border-t border-[#679186] pt-4"
    >
      <div class="flex flex-col space-y-3">
        <a
          href="/"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          🏠 Inicio
        </a>
        <a
          href="/servicios"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          📦 Servicios
        </a>
        <a
          href="/equipo"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          🚛 Nuestro Equipo
        </a>
        <a
          href="/precios"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          💰 Precios
        </a>
        <a
          href="/testimonios"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          ⭐ Testimonios
        </a>
        <a
          href="/contacto"
          class="block text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 font-medium text-base py-2 mobile-menu-link"
        >
          📞 Contacto
        </a>
        <div class="border-t border-[#679186] pt-3 mt-3">
          <div class="flex flex-col space-y-3">
            <a
              href="tel:+34933539792"
              class="flex items-center space-x-2 text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 py-2"
            >
              <span class="text-lg">📞</span>
              <span class="font-semibold">933 53 97 92</span>
            </a>
            <a
              href="https://wa.me/34640506084"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center space-x-2 text-[#bbd4ce] hover:text-[#FAE360] transition-colors duration-300 py-2"
            >
              <span class="text-lg">💬</span>
              <span class="font-semibold">WhatsApp</span>
            </a>
          </div>
        </div>
      </div>
    </nav>
  </div>

  <!-- Script para el menú móvil -->
  <script>
    // Función para inicializar el menú móvil
    function initializeMobileMenu() {
      const menuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");
      const menuLinks = document.querySelectorAll(".mobile-menu-link");

      // Limpiar eventos previos si existen
      if (menuButton && (menuButton as any)._mobileMenuInitialized) {
        return;
      }

      // Toggle del menú móvil
      if (menuButton && mobileMenu) {
        const handleMenuToggle = function () {
          mobileMenu.classList.toggle("hidden");

          // Cambiar icono del botón
          const svg = menuButton.querySelector("svg");
          const currentPath = svg?.querySelector("path");

          if (mobileMenu.classList.contains("hidden")) {
            // Mostrar icono de hamburguesa
            if (currentPath) {
              currentPath.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
            }
          } else {
            // Mostrar icono de X
            if (currentPath) {
              currentPath.setAttribute("d", "M6 18L18 6M6 6l12 12");
            }
          }
        };

        menuButton.addEventListener("click", handleMenuToggle);
        (menuButton as any)._mobileMenuInitialized = true;
      }

      // Cerrar menú al hacer click en un enlace
      menuLinks.forEach((link) => {
        if (!(link as any)._menuLinkInitialized) {
          const handleLinkClick = function () {
            if (mobileMenu) {
              mobileMenu.classList.add("hidden");
              // Restaurar icono de hamburguesa
              const svg = menuButton?.querySelector("svg");
              const currentPath = svg?.querySelector("path");
              if (currentPath) {
                currentPath.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
              }
            }
          };

          link.addEventListener("click", handleLinkClick);
          (link as any)._menuLinkInitialized = true;
        }
      });
    }

    // Inicializar en carga inicial
    initializeMobileMenu();

    // Reinicializar después de cada navegación con View Transitions
    document.addEventListener("astro:page-load", initializeMobileMenu);

    // Función para highlight y smooth scroll (funcionalidad separada)
    function initializeScrollBehavior() {
      // Smooth scroll para todos los enlaces de navegación
      const allNavLinks = document.querySelectorAll('a[href^="#"]');
      allNavLinks.forEach((link) => {
        if (!(link as any)._navLinkInitialized) {
          const handleNavClick = function (e: Event) {
            e.preventDefault();
            const anchor = e.currentTarget as HTMLAnchorElement;
            const targetId = anchor.getAttribute("href");
            const targetElement = targetId
              ? document.querySelector(targetId)
              : null;

            if (targetElement) {
              const headerElement = document.querySelector(
                "header"
              ) as HTMLElement;
              const headerHeight = headerElement?.offsetHeight || 80;
              const targetPosition =
                (targetElement as HTMLElement).offsetTop - headerHeight;

              window.scrollTo({
                top: targetPosition,
                behavior: "smooth",
              });
            }
          };

          link.addEventListener("click", handleNavClick);
          (link as any)._navLinkInitialized = true;
        }
      });

      // Destacar enlace activo en scroll
      function highlightActiveSection() {
        const sections = document.querySelectorAll("section[id]");
        const navLinks = document.querySelectorAll('nav a[href^="#"]');
        const headerElement = document.querySelector("header") as HTMLElement;
        const headerHeight = headerElement?.offsetHeight || 80;

        let current = "";
        sections.forEach((section) => {
          const htmlSection = section as HTMLElement;
          const sectionTop = htmlSection.offsetTop - headerHeight - 50;
          const sectionHeight = htmlSection.offsetHeight;

          if (
            window.scrollY >= sectionTop &&
            window.scrollY < sectionTop + sectionHeight
          ) {
            const sectionId = section.getAttribute("id");
            if (sectionId) {
              current = sectionId;
            }
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("text-[#FAE360]");
          link.classList.add("text-[#bbd4ce]");

          if (link.getAttribute("href") === `#${current}`) {
            link.classList.remove("text-[#bbd4ce]");
            link.classList.add("text-[#FAE360]");
          }
        });
      }

      // Ejecutar al hacer scroll
      window.addEventListener("scroll", highlightActiveSection);
      // Ejecutar al cargar la página
      highlightActiveSection();

      // --- NEW: measure header height and set CSS variable to avoid overlap ---
      const setHeaderHeightVar = () => {
        const header = document.querySelector("header");
        if (!header) return;
        const height = header.getBoundingClientRect().height;
        document.documentElement.style.setProperty(
          "--header-height",
          height + "px"
        );
      };

      // set on load and resize (debounced)
      setHeaderHeightVar();
      let resizeTimer: number | undefined;
      window.addEventListener("resize", () => {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(setHeaderHeightVar, 100);
      });

      // Also update after fonts/images load (in case header height changes)
      window.addEventListener("load", setHeaderHeightVar);

      // --- NEW: recalculate header height after each SPA navigation ---
      document.addEventListener("astro:page-load", () => {
        // Small delay to ensure DOM is fully rendered after navigation
        setTimeout(setHeaderHeightVar, 50);
      });

      // --- NEW: observe header size changes (handles badge animations and SPA view transitions) ---
      try {
        const headerEl = document.querySelector("header");
        if (headerEl && "ResizeObserver" in window) {
          const ro = new ResizeObserver(() => {
            setHeaderHeightVar();
          });
          ro.observe(headerEl);
        }
      } catch (e) {
        // ignore - ResizeObserver not available
      }

      // --- NEW: observe main content mutations (useful when navigating via ViewTransitions/SPA) ---
      try {
        let mutationTimer: number | undefined;
        const observeMain = () => {
          const main = document.querySelector("main");
          if (!main) return;
          const mo = new MutationObserver(() => {
            window.clearTimeout(mutationTimer);
            mutationTimer = window.setTimeout(() => {
              setHeaderHeightVar();
              // force a reflow to ensure layout updates
              void document.body.offsetHeight;
            }, 50);
          });
          mo.observe(main, { childList: true, subtree: true });
        };

        // In some SPA flows the <main> may be replaced; observe body for additions
        const bodyObserver = new MutationObserver(() => {
          observeMain();
        });
        bodyObserver.observe(document.body, {
          childList: true,
          subtree: false,
        });

        // Initial call
        observeMain();
      } catch (e) {
        // ignore mutation observer errors
      }
    }

    // Inicializar comportamiento de scroll
    initializeScrollBehavior();

    // Reinicializar después de cada navegación con View Transitions
    document.addEventListener("astro:page-load", initializeScrollBehavior);
  </script>

  <style>
    /* Truck logo animation */
    .truck-logo {
      animation: truckDriveIn 2s ease-out;
      animation-fill-mode: both;
    }

    /* Keyframes for truck driving in from left */
    @keyframes truckDriveIn {
      0% {
        transform: translateX(-200px) scale(0.8);
        opacity: 0;
      }
      60% {
        transform: translateX(10px) scale(1.05);
        opacity: 1;
      }
      80% {
        transform: translateX(-5px) scale(0.98);
      }
      100% {
        transform: translateX(0) scale(1);
        opacity: 1;
      }
    }

    /* Add some engine sound effect with subtle vibration on hover */
    .truck-logo:hover {
      animation: truckIdle 0.2s ease-in-out infinite alternate;
    }

    @keyframes truckIdle {
      0% {
        transform: translateX(0) translateY(0);
      }
      100% {
        transform: translateX(1px) translateY(-1px);
      }
    }

    /* On page transitions, replay the animation */
    .truck-logo.page-transition {
      animation: truckDriveIn 1.5s ease-out;
    }

    /* Prefers-reduced-motion support */
    @media (prefers-reduced-motion: reduce) {
      .truck-logo {
        animation: fadeIn 1s ease-out;
      }

      .truck-logo:hover {
        animation: none;
        transform: none;
      }

      @keyframes fadeIn {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }
    }
  </style>
</header>
