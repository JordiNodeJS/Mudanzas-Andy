---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  description: string;
  href: string;
  gradient?: string;
  external?: boolean;
  badge?: string;
}

const {
  iconName,
  title,
  description,
  href,
  gradient = "bg-gradient-to-br from-white to-slate-50",
  external = false,
  badge,
} = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class={`block ${gradient} p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-3 hover:scale-[1.03] group border-2 border-white/30 relative overflow-hidden card-enhanced backdrop-blur-sm`}
>
  <!-- Enhanced Badge with better visibility -->
  {
    badge && (
      <div class="absolute top-4 right-4 bg-gradient-to-r from-accent to-secondary text-white px-3 py-2 rounded-full text-xs font-bold shadow-lg animate-pulse">
        {badge}
      </div>
    )
  }

  <!-- Enhanced Background decoration with better contrast -->
  <div
    class="absolute inset-0 opacity-8 group-hover:opacity-15 transition-opacity duration-500"
  >
    <div
      class="absolute bottom-0 right-0 w-28 h-28 transform translate-x-10 translate-y-10"
    >
      <Icon name={iconName} class="w-full h-full text-secondary/30" />
    </div>
  </div>

  <div class="text-center relative z-10">
    <!-- Enhanced icon container with better visibility -->
    <div
      class="w-20 h-20 bg-gradient-to-br from-secondary/30 to-accent/30 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-md border border-white/20"
    >
      <Icon
        name={iconName}
        class="text-secondary group-hover:text-primary transition-colors duration-300"
        size={32}
      />
    </div>

    <!-- Enhanced title with better contrast -->
    <h3
      class="text-xl font-bold text-primary mb-4 group-hover:text-secondary transition-colors duration-300"
    >
      {title}
    </h3>

    <!-- Enhanced description with better readability -->
    <p class="text-gray-700 text-sm leading-relaxed font-medium mb-5">
      {description}
    </p>

    <!-- Enhanced arrow indicator with better visibility -->
    <div class="mt-6 flex justify-center">
      <div
        class="w-8 h-8 bg-gradient-to-r from-secondary/20 to-secondary/30 rounded-full flex items-center justify-center group-hover:bg-gradient-to-r group-hover:from-secondary group-hover:to-primary transition-all duration-300 shadow-md border border-secondary/20 group-hover:border-transparent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          class="w-4 h-4 text-secondary group-hover:text-white transition-colors duration-300"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </div>
    </div>
  </div>
</a>
