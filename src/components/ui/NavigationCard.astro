---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  description: string;
  href: string;
  gradient?: string;
  external?: boolean;
  badge?: string;
}

const {
  iconName,
  title,
  description,
  href,
  gradient = "bg-gradient-to-br from-white to-slate-50",
  external = false,
  badge,
} = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class={`block ${gradient} p-6 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-2 hover:scale-[1.02] group border border-slate-200/50 relative overflow-hidden`}
>
  <!-- Badge -->
  {
    badge && (
      <div class="absolute top-3 right-3 bg-gradient-to-r from-[#f9b4ab] to-[#679186] text-white px-2 py-1 rounded-full text-xs font-semibold">
        {badge}
      </div>
    )
  }

  <!-- Background decoration -->
  <div
    class="absolute inset-0 opacity-5 group-hover:opacity-10 transition-opacity"
  >
    <div
      class="absolute bottom-0 right-0 w-24 h-24 transform translate-x-8 translate-y-8"
    >
      <Icon name={iconName} class="w-full h-full text-[#679186]" />
    </div>
  </div>

  <div class="text-center relative z-10">
    <div
      class="w-16 h-16 bg-gradient-to-br from-[#679186]/20 to-[#f9b4ab]/20 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300"
    >
      <Icon
        name={iconName}
        class="text-[#679186] group-hover:text-[#264e70] transition-colors"
        size={28}
      />
    </div>

    <h3
      class="text-xl font-semibold text-[#264e70] mb-3 group-hover:text-[#679186] transition-colors"
    >
      {title}
    </h3>

    <p class="text-gray-600 text-sm leading-relaxed">
      {description}
    </p>

    <!-- Arrow indicator -->
    <div class="mt-4 flex justify-center">
      <div
        class="w-6 h-6 bg-[#679186]/10 rounded-full flex items-center justify-center group-hover:bg-[#679186] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="w-3 h-3 text-[#679186] group-hover:text-white transition-colors"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </div>
    </div>
  </div>
</a>
