---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  value: string;
  description?: string;
  href?: string;
  target?: string;
  gradient?: string;
  badge?: string;
}

const {
  iconName,
  title,
  value,
  description,
  href,
  target,
  gradient = "bg-gradient-to-br from-white to-slate-50",
  badge,
} = Astro.props;

// Definir el contenido del card como variables que luego reutilizaré
const cardClass = `${gradient} p-6 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 border border-slate-200/50 relative overflow-hidden group h-full flex flex-col justify-between`;
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={target === "_blank" ? "noopener noreferrer" : undefined}
      class="block h-full"
    >
      <div class={cardClass}>
        {/* Badge */}
        {badge && (
          <div class="absolute top-3 right-3 bg-gradient-to-r from-[#f9b4ab] to-[#679186] text-white px-2 py-1 rounded-full text-xs font-semibold">
            {badge}
          </div>
        )}

        {/* Background decoration */}
        <div class="absolute inset-0 opacity-5 group-hover:opacity-10 transition-opacity">
          <div class="absolute bottom-0 right-0 w-20 h-20 transform translate-x-6 translate-y-6">
            <Icon name={iconName} class="w-full h-full text-[#679186]" />
          </div>
        </div>

        <div class="relative z-10">
          {/* Icon and Title */}
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-gradient-to-br from-[#679186]/20 to-[#f9b4ab]/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <Icon
                name={iconName}
                class="text-[#679186] group-hover:text-[#264e70] transition-colors"
                size={24}
              />
            </div>

            <div class="flex-1">
              <h3 class="text-lg font-bold text-[#264e70] mb-1 group-hover:text-[#679186] transition-colors">
                {title}
              </h3>
              <p class="text-[#679186] font-semibold text-lg break-all">
                {value}
              </p>
              {description && (
                <p class="text-gray-600 text-sm mt-2">{description}</p>
              )}
            </div>
          </div>

          {/* Hover indicator */}
          <div class="flex justify-end opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="w-6 h-6 bg-[#679186]/10 rounded-full flex items-center justify-center group-hover:bg-[#679186] transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-3 h-3 text-[#679186] group-hover:text-white transition-colors"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  ) : (
    <div class={cardClass}>
      {/* Badge */}
      {badge && (
        <div class="absolute top-3 right-3 bg-gradient-to-r from-[#f9b4ab] to-[#679186] text-white px-2 py-1 rounded-full text-xs font-semibold">
          {badge}
        </div>
      )}

      {/* Background decoration */}
      <div class="absolute inset-0 opacity-5 group-hover:opacity-10 transition-opacity">
        <div class="absolute bottom-0 right-0 w-20 h-20 transform translate-x-6 translate-y-6">
          <Icon name={iconName} class="w-full h-full text-[#679186]" />
        </div>
      </div>

      <div class="relative z-10">
        {/* Icon and Title */}
        <div class="flex items-start gap-4 mb-4">
          <div class="w-12 h-12 bg-gradient-to-br from-[#679186]/20 to-[#f9b4ab]/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <Icon
              name={iconName}
              class="text-[#679186] group-hover:text-[#264e70] transition-colors"
              size={24}
            />
          </div>

          <div class="flex-1">
            <h3 class="text-lg font-bold text-[#264e70] mb-1 group-hover:text-[#679186] transition-colors">
              {title}
            </h3>
            <p class="text-[#679186] font-semibold text-lg break-all">
              {value}
            </p>
            {description && (
              <p class="text-gray-600 text-sm mt-2">{description}</p>
            )}
          </div>
        </div>

        {/* Hover indicator */}
        <div class="flex justify-end opacity-0 group-hover:opacity-100 transition-opacity">
          <div class="w-6 h-6 bg-[#679186]/10 rounded-full flex items-center justify-center group-hover:bg-[#679186] transition-colors">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-3 h-3 text-[#679186] group-hover:text-white transition-colors"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
              />
            </svg>
          </div>
        </div>
      </div>
    </div>
  )
}
