---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  value: string;
  description?: string;
  href?: string;
  target?: string;
  gradient?: string;
  badge?: string;
}

const {
  iconName,
  title,
  value,
  description,
  href,
  target,
  gradient = "bg-gradient-to-br from-white to-slate-50",
  badge,
} = Astro.props;

// Definir el contenido del card como variables que luego reutilizaré
const cardClass = `${gradient} p-5 lg:p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border-2 border-slate-200/50 hover:border-[#679186]/30 relative overflow-hidden group contact-card-enhanced`;
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={target === "_blank" ? "noopener noreferrer" : undefined}
      class="block h-full"
    >
      <div class={cardClass}>
        {/* Badge - Mejorado */}
        {badge && (
          <div class="absolute top-6 right-6 z-20 pointer-events-none bg-gradient-to-r from-[#f9b4ab] to-[#679186] text-white px-3 py-2 rounded-full text-xs font-bold shadow-lg lg:hidden">
            {badge}
          </div>
        )}

        {/* Background decoration - Más sutil pero visible */}
        <div class="absolute inset-0 opacity-8 group-hover:opacity-15 transition-opacity">
          <div class="absolute bottom-0 right-0 w-24 h-24 transform translate-x-8 translate-y-8">
            <Icon name={iconName} class="w-full h-full text-[#679186]/30" />
          </div>
        </div>

        <div class="relative z-10">
          {/* Icon and Title - Mejorado */}
          <div class="flex items-start gap-4 mb-4">
            <div class="w-14 h-14 bg-gradient-to-br from-[#679186]/20 to-[#f9b4ab]/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <Icon
                name={iconName}
                class="text-[#679186] group-hover:text-[#264e70] transition-colors"
                size={24}
              />
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="text-lg lg:text-base font-bold text-[#264e70] mb-1 leading-tight group-hover:text-[#679186] transition-colors">
                {title}
              </h3>
              <div class="min-w-0">
                <p class="text-[#679186] font-bold text-base whitespace-nowrap truncate">
                  {value}
                </p>
              </div>
              {description && (
                <p class="text-gray-600 text-sm mt-2 leading-relaxed">
                  {description}
                </p>
              )}
            </div>
          </div>

          {/* Hover indicator - Más compacto y contextual */}
          <div class="flex justify-end opacity-0 group-hover:opacity-100 transition-opacity mt-2">
            <div class="w-7 h-7 bg-[#679186]/10 rounded-full flex items-center justify-center group-hover:bg-[#679186] transition-colors shadow-md">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
                class="w-3.5 h-3.5 text-[#679186] group-hover:text-white transition-colors"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  ) : (
    <div class={cardClass}>
      {/* Badge */}
      {badge && (
        <div class="absolute top-6 right-6 z-20 pointer-events-none bg-gradient-to-r from-[#f9b4ab] to-[#679186] text-white px-2 py-1 rounded-full text-xs font-semibold lg:hidden">
          {badge}
        </div>
      )}

      {/* Background decoration */}
      <div class="absolute inset-0 opacity-5 group-hover:opacity-10 transition-opacity">
        <div class="absolute bottom-0 right-0 w-20 h-20 transform translate-x-6 translate-y-6">
          <Icon name={iconName} class="w-full h-full text-[#679186]" />
        </div>
      </div>

      <div class="relative z-10">
        {/* Icon and Title */}
        <div class="flex items-start gap-4 mb-4">
          <div class="w-12 h-12 bg-gradient-to-br from-[#679186]/20 to-[#f9b4ab]/20 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <Icon
              name={iconName}
              class="text-[#679186] group-hover:text-[#264e70] transition-colors"
              size={20}
            />
          </div>

          <div class="flex-1 min-w-0">
            <h3 class="text-base font-bold text-[#264e70] mb-1 group-hover:text-[#679186] transition-colors">
              {title}
            </h3>
            <div class="min-w-0">
              <p class="text-[#679186] font-semibold text-base whitespace-nowrap truncate">
                {value}
              </p>
            </div>
            {description && (
              <p class="text-gray-600 text-sm mt-2">{description}</p>
            )}
          </div>
        </div>

        {/* Hover indicator */}
        <div class="flex justify-end opacity-0 group-hover:opacity-100 transition-opacity mt-2">
          <div class="w-6 h-6 bg-[#679186]/10 rounded-full flex items-center justify-center group-hover:bg-[#679186] transition-colors">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-3 h-3 text-[#679186] group-hover:text-white transition-colors"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
              />
            </svg>
          </div>
        </div>
      </div>
    </div>
  )
}
