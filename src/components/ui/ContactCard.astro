---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  value: string;
  description?: string;
  href?: string;
  target?: string;
  gradient?: string;
  badge?: string;
}

const {
  iconName,
  title,
  value,
  description,
  href,
  target,
  gradient = "bg-gradient-to-br from-white to-slate-50",
  badge,
} = Astro.props;

// [THEMING] Mapeo de gradientes usando variables CSS como fuente de verdad
const gradientClassMap: Record<string, string> = {
  phone: "contact-card-gradient-phone",
  whatsapp: "contact-card-gradient-whatsapp",
  archive: "contact-card-gradient-email",
  globe: "contact-card-gradient-coverage",
};

// [RESPONSIVE] Layout horizontal como en el diseño original - layout simplificado y limpio
const cardClass = `${gradientClassMap[iconName] || gradient} p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-slate-200/50 hover:border-secondary/30 relative group contact-card-clean bg-white/80 backdrop-blur-sm`;
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={target === "_blank" ? "noopener noreferrer" : undefined}
      class="block h-full"
    >
      <div class={cardClass}>
        {/* Badge - Posicionado en la esquina superior derecha como en el diseño original */}
        {badge && (
          <div class="absolute top-4 right-4 z-10 badge-gradient-primary text-white px-3 py-1 rounded-full text-xs font-bold shadow-md">
            {badge}
          </div>
        )}

        {/* Layout horizontal como en las imágenes originales */}
        <div class="flex items-center gap-4">
          {/* Icon - Círculo con fondo temático */}
          <div class="w-14 h-14 icon-bg-theme rounded-full flex items-center justify-center flex-shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300">
            <Icon
              name={iconName}
              class="text-secondary group-hover:text-primary transition-colors duration-300"
              size={24}
            />
          </div>

          {/* Content - Información de contacto alineada verticalmente */}
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-bold text-primary mb-1 group-hover:text-secondary transition-colors duration-300">
              {title}
            </h3>
            <p class="text-secondary font-bold text-base mb-1 group-hover:text-primary transition-colors truncate">
              {value}
            </p>
            {description && (
              <p class="text-gray-600 text-sm leading-relaxed group-hover:text-gray-700 transition-colors">
                {description}
              </p>
            )}
          </div>

          {/* Indicador de hover - Flecha sutil a la derecha */}
          <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0">
            <div class="w-8 h-8 badge-gradient-primary rounded-full flex items-center justify-center shadow-sm">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
                class="w-4 h-4 text-white"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </a>
  ) : (
    <div class={cardClass}>
      {/* Badge para tarjetas no clicables */}
      {badge && (
        <div class="absolute top-4 right-4 z-10 badge-gradient-primary text-white px-3 py-1 rounded-full text-xs font-bold shadow-md">
          {badge}
        </div>
      )}

      {/* Layout horizontal igual que el clicable */}
      <div class="flex items-center gap-4">
        {/* Icon */}
        <div class="w-14 h-14 icon-bg-theme rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
          <Icon name={iconName} class="text-secondary" size={24} />
        </div>

        {/* Content */}
        <div class="flex-1 min-w-0">
          <h3 class="text-lg font-bold text-primary mb-1">{title}</h3>
          <p class="text-secondary font-bold text-base mb-1 truncate">
            {value}
          </p>
          {description && (
            <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
          )}
        </div>
      </div>
    </div>
  )
}
