---
import Icon from "./Icon.astro";

interface Props {
  iconName: string;
  title: string;
  description: string;
  features: string[];
  gradient: string;
  featured?: boolean;
  ctaText?: string;
  ctaLink?: string;
  badge?: string;
}

const {
  iconName,
  title,
  description,
  features,
  gradient,
  featured = false,
  ctaText = "Solicitar Presupuesto",
  ctaLink = "https://wa.me/34640506084",
  badge,
} = Astro.props;
---

<div
  class={`${gradient} relative overflow-hidden ${
    featured
      ? "p-6 lg:p-8 rounded-3xl shadow-lg hover:shadow-2xl border-2 border-accent transform hover:scale-[1.02]"
      : "p-5 lg:p-6 rounded-2xl shadow-sm hover:shadow-lg border border-opacity-30 transform hover:-translate-y-1"
  } transition-all duration-300 bg-white/90 backdrop-blur-sm group`}
>
  <!-- Badge para servicios destacados -->
  {
    badge && (
      <div class="absolute top-4 right-4 bg-gradient-to-r from-accent to-secondary text-white px-3 py-1 rounded-full text-xs font-semibold">
        {badge}
      </div>
    )
  }

  <!-- Decorative background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div
      class="absolute top-0 right-0 w-32 h-32 transform rotate-45 translate-x-16 -translate-y-16"
    >
      <Icon name={iconName} class="w-full h-full text-primary" />
    </div>
  </div>

  <div class="relative z-10">
    <!-- Header con icono y título -->
    <div class="flex items-start gap-4 mb-4">
      <div
        class={`${
          featured
            ? "w-20 h-20 bg-gradient-to-br from-accent to-secondary shadow-lg"
            : "w-16 h-16 bg-gradient-to-br from-secondary/20 to-accent/20"
        } rounded-xl flex items-center justify-center text-white transition-transform duration-300 group-hover:scale-110`}
      >
        <Icon
          name={iconName}
          class={`${featured ? "text-white" : "text-secondary"}`}
          size={featured ? 32 : 28}
        />
      </div>

      <div class="flex-1">
        <h3
          class={`${
            featured ? "text-xl lg:text-2xl" : "text-lg lg:text-xl"
          } font-bold text-primary mb-2 group-hover:text-secondary transition-colors`}
        >
          {title}
        </h3>
        <p
          class={`text-slate-600 ${
            featured ? "text-base lg:text-lg" : "text-sm lg:text-base"
          }`}
        >
          {description}
        </p>
      </div>
    </div>

    <!-- Features list -->
    <div
      class={`${featured ? "text-base" : "text-sm lg:text-sm"} text-slate-800 font-medium mb-6`}
    >
      <ul class="space-y-3">
        {
          features.map((feature) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-green-600 inline-flex items-center flex-shrink-0">
                <Icon name="check" class="text-green-600" size={16} />
              </span>
              <span class="break-words hyphens-auto text-slate-700 leading-relaxed">
                {feature}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- CTA Button -->
    <div class="flex gap-3">
      <a
        href={ctaLink}
        target="_blank"
        rel="noopener noreferrer"
        class={`${
          featured
            ? "flex-1 bg-gradient-to-r from-accent to-secondary text-white hover:from-secondary hover:to-accent shadow-lg hover:shadow-xl"
            : "flex-1 bg-secondary text-white hover:bg-primary"
        } px-4 py-3 rounded-lg font-semibold text-center transition-all duration-300 transform hover:scale-105 text-sm lg:text-base`}
      >
        <Icon name="whatsapp" class="inline w-4 h-4 mr-2" />
        {ctaText}
      </a>

      {
        featured && (
          <a
            href="tel:+34933539792"
            class="px-4 py-3 bg-white border-2 border-secondary text-secondary hover:bg-secondary hover:text-white rounded-lg font-semibold transition-all duration-300 transform hover:scale-105"
          >
            <Icon name="phone" class="w-4 h-4" />
          </a>
        )
      }
    </div>
  </div>
</div>
