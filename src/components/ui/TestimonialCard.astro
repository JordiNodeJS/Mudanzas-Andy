---
interface Props {
  icon: string;
  title: string;
  description: string;
  name: string;
  location: string;
  rating: number;
}

const { icon, title, description, name, location, rating } = Astro.props;

const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => (i < rating ? "⭐" : "☆")).join(
    ""
  );
};
---

<div
  class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-lg border border-white/20"
>
  <!-- Icon -->
  <div class="text-4xl mb-4 text-center">{icon}</div>

  <!-- Service Title -->
  <h3 class="text-primary font-bold text-lg mb-3 text-center">{title}</h3>

  <!-- Service Description -->
  <p
    class="text-secondary mb-4 text-sm lg:text-base italic text-center leading-relaxed"
  >
    "{description}"
  </p>

  <!-- Rating Stars -->
  <div class="text-2xl mb-3 text-center">{renderStars(rating)}</div>

  <!-- Author: mejorar contraste usando colores del sitio -->
  <div class="text-center">
    <p class="font-semibold text-sm lg:text-base text-primary">- {name}</p>
    <p class="text-xs lg:text-sm text-secondary">{location}</p>
  </div>
</div>
