---
interface Props {
  name: string;
  location: string;
  text: string;
  rating: number;
}

const { name, location, text, rating } = Astro.props;

const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => (i < rating ? "⭐" : "☆")).join(
    ""
  );
};
---

<div
  class="bg-white/98 backdrop-blur-sm p-6 rounded-xl shadow-lg border border-[rgba(var(--color-primary),0.1)]"
>
  <div class="text-2xl mb-3">{renderStars(rating)}</div>
  <p class="text-primary mb-4 text-sm lg:text-base italic">
    "{text}"
  </p>
  <div class="text-secondary">
    <p class="font-semibold text-sm lg:text-base text-primary">{name}</p>
    <p class="text-xs lg:text-sm text-secondary opacity-90">{location}</p>
  </div>
</div>
