---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  class: className = "",
  loading = "lazy",
  width,
  height,
} = Astro.props;
---

<div class={`relative overflow-hidden ${className}`}>
  <!-- Imagen directa - sin lazy loading complejo -->
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
    width={width}
    height={height}
    class="w-full h-full object-cover transition-opacity duration-300"
  />
</div>
