---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ContactCard from "../components/ui/ContactCard.astro";
import ValueCard from "../components/ui/ValueCard.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";
import Icon from "../components/ui/Icon.astro";

const title = "Contacto | Mudanzas ANDY Barcelona";
const description =
  "Contacta con Mudanzas ANDY para tu presupuesto gratuito. Whatsapp, teléfono y formulario online. Respuesta inmediata para mudanzas en Barcelona y España.";

const breadcrumbItems = [{ label: "Inicio", href: "/" }, { label: "Contacto" }];
---

<Layout title={title} description={description}>
  <Header />

  <main class="contact-enhanced">
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="section-spacing-loose relative overflow-hidden">
      <!-- Background with patterns and gradients -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-[#679186] via-[#264e70] to-[#679186]"
      >
      </div>

      <!-- Decorative background elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-20 right-10 w-32 h-32 bg-gradient-to-br from-[#f9b4ab] to-white rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-20 left-10 w-48 h-48 bg-gradient-to-br from-white to-[#fdebd3] rounded-full blur-3xl"
        >
        </div>
      </div>

      <!-- Pattern overlay -->
      <div
        class="absolute inset-0 opacity-5"
        style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 20px 20px;"
      >
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center">
          <div class="lg:col-10">
            <!-- Badge -->
            <div
              class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-6"
            >
              <span class="w-2 h-2 bg-[#f9b4ab] rounded-full animate-pulse"
              ></span>
              <span
                class="text-white font-semibold text-sm uppercase tracking-wide"
                >Contacto Inmediato</span
              >
            </div>

            <h1
              class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6"
            >
              ¡Hablemos de tu Mudanza!
            </h1>
            <p class="text-white/90 text-lg lg:text-xl max-w-3xl mx-auto mb-8">
              <strong>Presupuesto GRATIS</strong> en menos de 5 minutos. Atención
              personalizada 24/7 para resolver todas tus dudas.
            </p>

            <!-- Enhanced Quick CTA buttons with better visibility -->
            <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
              <a
                href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-5 px-10 rounded-2xl shadow-2xl hover:shadow-3xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-1 inline-flex items-center justify-center gap-3 border-2 border-[#25D366]/30"
              >
                <Icon name="whatsapp" class="text-white" size={28} />
                <span class="text-lg">WhatsApp: Respuesta en 2 min</span>
              </a>

              <a
                href="tel:+34933539792"
                class="bg-white/20 backdrop-blur-sm border-2 border-white text-white hover:bg-white hover:text-[#264e70] font-bold py-5 px-10 rounded-2xl shadow-2xl hover:shadow-3xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-1 inline-flex items-center justify-center gap-3"
              >
                <Icon name="phone" class="text-current" size={28} />
                <span class="text-lg">Llamar: 933 53 97 92</span>
              </a>
            </div>

            <!-- Enhanced trust indicators with better spacing -->
            <div
              class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto"
            >
              <div
                class="bg-white/15 backdrop-blur-sm rounded-2xl p-6 border border-white/20"
              >
                <div class="text-3xl mb-3">⚡</div>
                <div class="text-white font-bold text-base mb-2">
                  Respuesta Inmediata
                </div>
                <div class="text-white/90 text-sm">En menos de 5 minutos</div>
              </div>
              <div
                class="bg-white/15 backdrop-blur-sm rounded-2xl p-6 border border-white/20"
              >
                <div class="text-3xl mb-3">🔒</div>
                <div class="text-white font-bold text-base mb-2">
                  Presupuesto Sin Compromiso
                </div>
                <div class="text-white/90 text-sm">
                  100% gratuito y sin letra pequeña
                </div>
              </div>
              <div
                class="bg-white/15 backdrop-blur-sm rounded-2xl p-6 border border-white/20"
              >
                <div class="text-3xl mb-3">📞</div>
                <div class="text-white font-bold text-base mb-2">
                  Atención 24/7
                </div>
                <div class="text-white/90 text-sm">
                  Siempre disponibles para ti
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Information -->
    <section class="section-spacing relative overflow-hidden">
      <!-- Background -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-[#f9b4ab]/10"
      >
      </div>

      <!-- Decorative elements -->
      <div class="absolute inset-0 opacity-15">
        <div
          class="absolute top-20 left-10 w-40 h-40 bg-gradient-to-br from-[#679186] to-[#f9b4ab] rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-20 right-10 w-56 h-56 bg-gradient-to-br from-[#fdebd3] to-[#bbd4ce] rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row items-center">
          <div class="lg:col-6 mb-12 lg:mb-0">
            <!-- Header -->
            <div class="mb-10">
              <div
                class="inline-flex items-center gap-2 bg-gradient-to-r from-[#f9b4ab]/30 to-[#679186]/30 px-5 py-3 rounded-full mb-6"
              >
                <span class="w-3 h-3 bg-[#679186] rounded-full animate-pulse"
                ></span>
                <span
                  class="text-[#679186] font-bold text-sm uppercase tracking-wide"
                  >Múltiples Formas de Contacto</span
                >
              </div>

              <h2
                class="text-3xl lg:text-4xl font-bold bg-gradient-to-r from-[#264e70] to-[#679186] bg-clip-text text-transparent mb-6"
              >
                Información de Contacto
              </h2>
              <p class="text-gray-700 text-lg lg:text-xl leading-relaxed">
                Elige la forma que más te convenga para contactarnos.
                <strong class="text-[#679186] block mt-2"
                  >Respuesta garantizada en menos de 5 minutos.</strong
                >
              </p>
            </div>

            <!-- Contact Cards Grid - Mejorado para desktop -->
            <!-- Añadimos utilidades grid para garantizar columnas responsive -->
            <div
              class="contact-grid-desktop grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-10"
            >
              <ContactCard
                iconName="phone"
                title="Teléfono Directo"
                value="933 53 97 92"
                description="Atención inmediata 24/7"
                href="tel:+34933539792"
                gradient="bg-gradient-to-br from-[#264e70]/25 via-white/40 to-[#679186]/20"
                badge="📞 INMEDIATO"
              />

              <ContactCard
                iconName="whatsapp"
                title="WhatsApp"
                value="640 50 60 84"
                description="Presupuesto gratis en 5 min"
                href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                target="_blank"
                gradient="bg-gradient-to-br from-[#25D366]/30 via-white/45 to-[#128C7E]/25"
                badge="⚡ PREFERIDO"
              />

              <ContactCard
                iconName="archive"
                title="Email"
                value="info@mudanzasandy.com"
                description="Consultas detalladas"
                href="mailto:info@mudanzasandy.com"
                gradient="bg-gradient-to-br from-[#f9b4ab]/25 via-white/40 to-[#ff9999]/20"
                badge="📧 COMPLETO"
              />

              <ContactCard
                iconName="globe"
                title="Cobertura"
                value="Barcelona y España"
                description="Servicio nacional completo"
                gradient="bg-gradient-to-br from-[#6b7280]/20 via-white/35 to-[#9ca3af]/15"
                badge="🌍 NACIONAL"
              />
            </div>

            <!-- Enhanced CTA Section -->
            <div
              class="bg-gradient-to-r from-[#f9b4ab]/20 to-[#679186]/20 backdrop-blur-sm border-2 border-[#679186]/30 rounded-2xl p-8 lg:p-10 shadow-lg"
            >
              <div class="text-center mb-6">
                <h3
                  class="text-xl lg:text-2xl font-bold text-[#264e70] mb-4 flex items-center justify-center gap-3"
                >
                  <span class="text-3xl">🚨</span>
                  ¿Necesitas atención urgente?
                </h3>
                <p class="text-gray-700 text-lg">
                  Nuestro equipo está disponible 24/7 para emergencias y
                  mudanzas urgentes.
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                  href="https://wa.me/34640506084?text=URGENTE: Necesito mudanza inmediata"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta-urgent flex-1 max-w-xs mx-auto sm:mx-0 bg-gradient-to-r from-[#25D366] to-[#128C7E] text-white px-8 py-4 rounded-xl font-bold text-center hover:from-[#128C7E] hover:to-[#25D366] transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-[#25D366]/30"
                >
                  � WhatsApp Urgente
                </a>

                <a
                  href="tel:+34933539792"
                  class="cta-urgent flex-1 max-w-xs mx-auto sm:mx-0 bg-white border-3 border-[#679186] text-[#679186] px-8 py-4 rounded-xl font-bold text-center hover:bg-[#679186] hover:text-white transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-[#679186]/30"
                >
                  📞 Llamar Ahora
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form Section - SEPARATED -->
    <section class="section-spacing relative overflow-hidden">
      <!-- Background -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-white via-[#f9b4ab]/5 to-slate-50"
      >
      </div>

      <!-- Decorative elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-10 right-20 w-32 h-32 bg-gradient-to-br from-[#264e70] to-[#679186] rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-10 left-20 w-48 h-48 bg-gradient-to-br from-[#f9b4ab] to-[#fdebd3] rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row justify-center">
          <div class="lg:col-8">
            <!-- Form Header -->
            <div class="text-center mb-12">
              <div
                class="inline-flex items-center gap-2 bg-gradient-to-r from-[#679186]/30 to-[#f9b4ab]/30 px-5 py-3 rounded-full mb-6"
              >
                <span class="w-3 h-3 bg-[#f9b4ab] rounded-full animate-pulse"
                ></span>
                <span
                  class="text-[#679186] font-bold text-sm uppercase tracking-wide"
                  >Formulario de Contacto</span
                >
              </div>

              <h2
                class="text-3xl lg:text-4xl font-bold bg-gradient-to-r from-[#264e70] to-[#679186] bg-clip-text text-transparent mb-6"
              >
                Solicita tu Presupuesto GRATIS
              </h2>
              <p
                class="text-gray-700 text-lg lg:text-xl leading-relaxed max-w-2xl mx-auto"
              >
                Completa el formulario y recibe tu presupuesto personalizado sin
                compromiso.
              </p>
            </div>

            <!-- Enhanced Contact Form -->
            <div
              class="bg-white rounded-3xl shadow-xl border border-slate-200/50 p-8 lg:p-10 backdrop-blur-sm max-w-2xl mx-auto"
            >
              <ContactForm variant="inline" />

              <!-- Form Footer -->
              <div class="mt-8 pt-6 border-t border-gray-100">
                <div class="space-y-3">
                  <div class="flex items-center gap-3 text-sm text-gray-700">
                    <Icon
                      name="check"
                      class="text-green-600 flex-shrink-0"
                      size={18}
                    />
                    <span class="font-medium"
                      >Tus datos están 100% seguros y protegidos</span
                    >
                  </div>
                  <div class="flex items-center gap-3 text-sm text-gray-700">
                    <Icon
                      name="check"
                      class="text-green-600 flex-shrink-0"
                      size={18}
                    />
                    <span class="font-medium"
                      >Respuesta garantizada en menos de 2 horas</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Guarantees Section - Mejorada para mayor visibilidad -->
    <section class="py-20 lg:py-28 relative overflow-hidden section-spacing">
      <!-- Background con mejor contraste -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-[#264e70] via-[#679186] to-[#264e70]"
      >
      </div>

      <!-- Pattern overlay mejorado -->
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 2px 2px, white 2px, transparent 0); background-size: 40px 40px;"
      >
      </div>

      <!-- Decorative elements con mayor visibilidad -->
      <div class="absolute inset-0 opacity-20">
        <div
          class="absolute top-20 left-20 w-60 h-60 bg-gradient-to-br from-[#f9b4ab] to-white rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-20 right-20 w-80 h-80 bg-gradient-to-br from-white to-[#fdebd3] rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center mb-16">
          <div class="lg:col-10">
            <!-- Badge mejorado -->
            <div
              class="inline-flex items-center gap-3 bg-white/20 backdrop-blur-sm px-6 py-3 rounded-full mb-8"
            >
              <span class="w-3 h-3 bg-[#f9b4ab] rounded-full animate-pulse"
              ></span>
              <span class="text-white font-bold text-sm uppercase tracking-wide"
                >Garantía de Excelencia</span
              >
            </div>

            <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
              ¿Por qué elegir Mudanzas ANDY?
            </h2>
            <p
              class="text-white/95 text-xl lg:text-2xl max-w-4xl mx-auto leading-relaxed"
            >
              Nuestra garantía de servicio y compromiso con la excelencia
            </p>
          </div>
        </div>

        <!-- Grid de valores mejorada para desktop -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10"
        >
          <div class="text-center">
            <ValueCard
              iconName="bolt"
              title="Respuesta Inmediata"
              description="Te respondemos en menos de 5 minutos, cualquier día del año"
              gradient="bg-white/15 backdrop-blur-md border-2 border-white/30 hover:bg-white/20 hover:border-white/40"
            />
          </div>

          <div class="text-center">
            <ValueCard
              iconName="check"
              title="Presupuesto Sin Sorpresas"
              description="Precio final cerrado sin costes ocultos ni letra pequeña"
              gradient="bg-white/15 backdrop-blur-md border-2 border-white/30 hover:bg-white/20 hover:border-white/40"
            />
          </div>

          <div class="text-center">
            <ValueCard
              iconName="archive"
              title="Seguro Incluido"
              description="Cobertura completa de responsabilidad civil hasta 30.000€"
              gradient="bg-white/15 backdrop-blur-md border-2 border-white/30 hover:bg-white/20 hover:border-white/40"
            />
          </div>

          <div class="text-center">
            <ValueCard
              iconName="truck"
              title="+14 Años Experiencia"
              description="Miles de mudanzas exitosas y clientes satisfechos"
              gradient="bg-white/15 backdrop-blur-md border-2 border-white/30 hover:bg-white/20 hover:border-white/40"
            />
          </div>
        </div>

        <!-- Final CTA - Mejorado y más visible -->
        <div class="row justify-center text-center mt-16">
          <div class="lg:col-10">
            <div
              class="bg-white/15 backdrop-blur-md border-2 border-white/30 rounded-3xl p-10 lg:p-12"
            >
              <h3
                class="text-3xl lg:text-4xl font-bold text-white mb-6 flex items-center justify-center gap-4"
              >
                <span class="text-4xl">🎯</span>
                ¡No esperes más!
              </h3>
              <p
                class="text-white/95 text-xl lg:text-2xl mb-8 max-w-3xl mx-auto leading-relaxed"
              >
                Cada minuto cuenta cuando planificas tu mudanza. Contactanos
                ahora y asegura tu fecha.
              </p>
              <div
                class="flex flex-col sm:flex-row gap-6 justify-center max-w-2xl mx-auto"
              >
                <a
                  href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-5 px-8 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-4 text-lg focus:outline-none focus:ring-4 focus:ring-[#25D366]/50"
                >
                  <Icon name="whatsapp" class="text-white" size={28} />
                  WhatsApp: ¡Respuesta en 2 min!
                </a>

                <a
                  href="tel:+34933539792"
                  class="flex-1 bg-white text-[#264e70] hover:bg-gray-100 font-bold py-5 px-8 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-4 text-lg focus:outline-none focus:ring-4 focus:ring-white/50"
                >
                  <Icon name="phone" class="text-[#264e70]" size={28} />
                  Llamar: 933 53 97 92
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
