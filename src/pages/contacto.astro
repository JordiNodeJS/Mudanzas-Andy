---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";

const title = "Contacto | Mudanzas ANDY Barcelona";
const description =
  "Contacta con Mudanzas ANDY para tu presupuesto gratuito. Whatsapp, teléfono y formulario online. Respuesta inmediata para mudanzas en Barcelona y España.";

const breadcrumbItems = [{ label: "Inicio", href: "/" }, { label: "Contacto" }];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="bg-gradient-to-b from-[#679186] to-[#264e70] py-8">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">
              Contacto
            </h1>
            <p class="text-white/90 text-lg max-w-2xl">
              Ponte en contacto con nosotros. Presupuesto gratuito sin
              compromiso.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Information -->
    <section class="py-16">
      <div class="container">
        <div class="row">
          <div class="lg:col-6 mb-8 lg:mb-0">
            <h2 class="text-2xl font-bold text-[#264e70] mb-6">
              Información de Contacto
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Card: Telephone -->
              <div
                class="flex items-start gap-4 bg-[#FBF3E8] rounded-lg p-4 shadow-sm border border-[#F3E8D8]"
              >
                <div
                  class="w-12 h-12 rounded-lg flex items-center justify-center text-white bg-gradient-to-br from-[#6ea597] to-[#3b6b80] text-xl"
                >
                  📞
                </div>
                <div>
                  <h3 class="font-semibold text-[#153745]">Teléfono</h3>
                  <p class="text-gray-600 text-sm">
                    <a
                      href="tel:+34933539792"
                      class="hover:text-[#679186] transition-colors"
                      >933 53 97 92</a
                    >
                  </p>
                </div>
              </div>

              <!-- Card: WhatsApp -->
              <div
                class="flex items-start gap-4 bg-[#FBF3E8] rounded-lg p-4 shadow-sm border border-[#F3E8D8]"
              >
                <div
                  class="w-12 h-12 rounded-lg flex items-center justify-center text-white bg-gradient-to-br from-[#6ea597] to-[#3b6b80] text-xl"
                >
                  💬
                </div>
                <div>
                  <h3 class="font-semibold text-[#153745]">WhatsApp</h3>
                  <p class="text-gray-600 text-sm">
                    <a
                      href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-[#679186] transition-colors"
                      >640 50 60 84</a
                    >
                  </p>
                </div>
              </div>

              <!-- Card: Email -->
              <div
                class="flex items-start gap-4 bg-[#FBF3E8] rounded-lg p-4 shadow-sm border border-[#F3E8D8]"
              >
                <div
                  class="w-12 h-12 rounded-lg flex items-center justify-center text-white bg-gradient-to-br from-[#6ea597] to-[#3b6b80] text-xl"
                >
                  📧
                </div>
                <div>
                  <h3 class="font-semibold text-[#153745]">Email</h3>
                  <p class="text-gray-600 text-sm">
                    <a
                      href="mailto:info@mudanzasandy.com"
                      class="hover:text-[#679186] transition-colors"
                      >info@mudanzasandy.com</a
                    >
                  </p>
                </div>
              </div>

              <!-- Card: Ubicación / Horarios combined -->
              <div
                class="flex items-start gap-4 bg-[#FBF3E8] rounded-lg p-4 shadow-sm border border-[#F3E8D8] col-span-1 sm:col-span-2"
              >
                <div
                  class="w-12 h-12 rounded-lg flex items-center justify-center text-white bg-gradient-to-br from-[#6ea597] to-[#3b6b80] text-xl"
                >
                  📍
                </div>
                <div>
                  <h3 class="font-semibold text-[#153745]">
                    Ubicación & Horarios
                  </h3>
                  <p class="text-gray-600 text-sm">
                    Barcelona y toda España · Servicio 24/7
                  </p>
                  <p class="text-gray-500 text-xs mt-2">
                    Atención telefónica inmediata — disponible todos los días
                  </p>
                </div>
              </div>
            </div>

            <!-- Quick CTA -->
            <div class="mt-6 flex flex-col sm:flex-row gap-3">
              <a
                href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 bg-[#FAE360] hover:bg-[#f0d84a] text-[#264e70] font-bold py-3 px-5 rounded-lg shadow transition-all"
              >
                <span class="text-xl">💬</span>
                Contactar por WhatsApp
              </a>

              <a
                href="tel:+34933539792"
                class="inline-flex items-center gap-3 border-2 border-[#679186] text-[#264e70] hover:bg-[#679186] hover:text-white font-semibold py-3 px-5 rounded-lg transition-all"
              >
                <span class="text-xl">📞</span>
                Llamar ahora
              </a>
            </div>
          </div>

          <div class="lg:col-6">
            <h2 class="text-2xl font-bold text-[#264e70] mb-6">
              Solicita tu Presupuesto
            </h2>
            <ContactForm variant="inline" />
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Actions -->
    <section class="bg-gradient-to-r from-[#679186] to-[#264e70] py-16">
      <div class="container">
        <div class="row justify-center text-center">
          <div class="lg:col-8">
            <h2 class="text-3xl font-bold text-white mb-4">¡Contacta Ahora!</h2>
            <p class="text-white/90 text-lg mb-8">
              Respuesta inmediata para tu mudanza
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-[#FAE360] hover:bg-[#f0d84a] text-[#264e70] font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-2"
              >
                <span class="text-xl">💬</span>
                WhatsApp GRATIS
              </a>

              <a
                href="tel:+34933539792"
                class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#264e70] font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-2"
              >
                <span class="text-xl">📞</span>
                Llamar: 933 53 97 92
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
