---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";

const title = "Testimonios de Clientes Satisfechos | Mudanzas ANDY";
const description =
  "Lee las experiencias reales de nuestros clientes. Más de 500 mudanzas exitosas en Barcelona y España. Opiniones verificadas y testimonios auténticos.";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Testimonios" },
];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="bg-gradient-to-b from-secondary to-primary py-8">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">
              Testimonios
            </h1>
            <p class="text-white/90 text-lg max-w-2xl">
              Experiencias reales de clientes satisfechos. Más de 500 mudanzas
              exitosas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Content - CON EL ESTILO ORIGINAL -->
    <TestimonialsSection />

    <!-- Call to Action -->
    <section class="bg-gradient-to-r from-secondary to-primary py-16">
      <div class="container">
        <div class="row justify-center text-center">
          <div class="lg:col-8">
            <h2 class="text-3xl font-bold text-white mb-4">
              ¿Quieres ser nuestro próximo cliente satisfecho?
            </h2>
            <p class="text-white/90 text-lg mb-8">
              Únete a las más de 500 familias que han confiado en nosotros
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://wa.me/34640506084?text=Hola! Quiero solicitar una mudanza"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-highlight hover:bg-[#f0d84a] text-primary font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-2"
              >
                <span class="text-xl">💬</span>
                WhatsApp GRATIS
              </a>

              <a
                href="tel:+34933539792"
                class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-primary font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 inline-flex items-center justify-center gap-2"
              >
                <span class="text-xl">📞</span>
                Llamar: 933 53 97 92
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
