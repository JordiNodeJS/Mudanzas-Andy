---
import Layout from "../layouts/Layout.astro";
import ServiceCardHybrid from "../components/ServiceCardHybrid.astro";
import { ServiceCardShadcn } from "../components/ServiceCardShadcn";

const testServiceData = {
  icon: "🚛",
  title: "Mudanzas Residenciales",
  description: "Servicio completo para mudanzas de hogar y oficina",
  features: [
    "Embalaje profesional",
    "Transporte seguro",
    "Montaje de muebles",
    "Seguro incluido",
  ],
};
---

<Layout>
  <main class="container mx-auto py-20 px-4">
    <h1 class="text-3xl font-bold text-center mb-12 text-[#264e70]">
      Test ServiceCard Migration
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Versión Original -->
      <div>
        <h2 class="text-xl font-semibold mb-4 text-[#264e70]">
          Original ServiceCard (Legacy)
        </h2>
        <div
          class="bg-gradient-to-br from-blue-50 to-slate-100 p-4 lg:p-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 border border-opacity-30"
        >
          <div class="text-3xl lg:text-4xl mb-3 lg:mb-4">🚛</div>
          <h3 class="text-lg lg:text-xl font-bold text-[#264e70] mb-2 lg:mb-3">
            Mudanzas Residenciales
          </h3>
          <p class="text-[#679186] mb-3 lg:mb-4 text-sm lg:text-base">
            Servicio completo para mudanzas de hogar y oficina
          </p>
          <div class="text-xs lg:text-sm text-[#264e70] font-semibold">
            <ul class="space-y-1">
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span>
                <span class="break-words hyphens-auto"
                  >Embalaje profesional</span
                >
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span>
                <span class="break-words hyphens-auto">Transporte seguro</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span>
                <span class="break-words hyphens-auto">Montaje de muebles</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span>
                <span class="break-words hyphens-auto">Seguro incluido</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Versión Híbrida shadcn/ui -->
      <div>
        <h2 class="text-xl font-semibold mb-4 text-[#264e70]">
          ServiceCard Hybrid (shadcn/ui)
        </h2>
        <ServiceCardHybrid {...testServiceData} gradient="primary" />
      </div>

      <!-- Versión React shadcn/ui -->
      <div class="md:col-span-2">
        <h2 class="text-xl font-semibold mb-4 text-[#264e70]">
          ServiceCard React (shadcn/ui) - Con diferentes gradientes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <ServiceCardShadcn
            {...testServiceData}
            gradient="primary"
            client:load
          />
          <ServiceCardShadcn
            {...testServiceData}
            gradient="secondary"
            client:load
          />
          <ServiceCardShadcn
            {...testServiceData}
            gradient="accent"
            client:load
          />
          <ServiceCardShadcn
            {...testServiceData}
            gradient="neutral"
            client:load
          />
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="/" class="text-[#264e70] underline"
        >← Volver a la página principal</a
      >
    </div>
  </main>
</Layout>
