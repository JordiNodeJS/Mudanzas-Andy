---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import NavigationCard from "../components/ui/NavigationCard.astro";

const title = "Mudanzas profesionales en Barcelona y España | Mudanzas ANDY";
const description =
  "Mudanzas profesionales en Barcelona y toda España. Presupuesto GRATIS en 5 minutos por WhatsApp. Atención 24/7. ¡Tu mudanza, nuestra prioridad!";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Hero Section -->
    <HeroSection />

    <!-- Navigation Cards Section -->
    <section class="py-16 lg:py-20 relative overflow-hidden">
      <!-- Background with enhanced gradients -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-[#f9b4ab]/5"
      >
      </div>

      <!-- Decorative elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-10 right-20 w-24 h-24 bg-gradient-to-br from-[#679186] to-[#f9b4ab] rounded-full blur-2xl"
        >
        </div>
        <div
          class="absolute bottom-10 left-20 w-32 h-32 bg-gradient-to-br from-[#fdebd3] to-[#bbd4ce] rounded-full blur-2xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center mb-12 lg:mb-16">
          <div class="lg:col-10">
            <div
              class="inline-flex items-center gap-2 bg-gradient-to-r from-[#f9b4ab]/20 to-[#679186]/20 px-4 py-2 rounded-full mb-6"
            >
              <span class="w-2 h-2 bg-[#679186] rounded-full animate-pulse"
              ></span>
              <span
                class="text-[#679186] font-semibold text-sm uppercase tracking-wide"
                >Navega por Nuestros Servicios</span
              >
            </div>

            <h2
              class="text-3xl lg:text-4xl font-bold bg-gradient-to-r from-[#264e70] to-[#679186] bg-clip-text text-transparent mb-4"
            >
              Descubre Nuestros Servicios
            </h2>
            <p class="text-gray-600 text-lg lg:text-xl max-w-3xl mx-auto">
              Explora todo lo que ofrecemos para hacer de tu mudanza una
              <strong class="text-[#679186]">experiencia perfecta</strong> y sin
              preocupaciones
            </p>
          </div>
        </div>

        <div class="row">
          <!-- Services Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="package"
              title="Servicios"
              description="Mudanzas locales, nacionales, internacionales y más"
              href="/servicios"
              gradient="bg-gradient-to-br from-[#f9b4ab]/10 to-[#fdebd3]/20"
              badge="⭐ POPULAR"
            />
          </div>

          <!-- Team Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="truck"
              title="Nuestro Equipo"
              description="Profesionales experimentados y comprometidos"
              href="/equipo"
              gradient="bg-gradient-to-br from-[#679186]/10 to-[#bbd4ce]/20"
            />
          </div>

          <!-- Pricing Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="archive"
              title="Precios"
              description="Tarifas transparentes y presupuesto gratuito"
              href="/precios"
              gradient="bg-gradient-to-br from-[#fdebd3]/20 to-[#f9b4ab]/10"
            />
          </div>

          <!-- Testimonials Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="check"
              title="Testimonios"
              description="Experiencias reales de clientes satisfechos"
              href="/testimonios"
              gradient="bg-gradient-to-br from-[#bbd4ce]/20 to-[#679186]/10"
            />
          </div>

          <!-- Contact Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="phone"
              title="Contacto"
              description="Hablemos de tu mudanza. Atención 24/7"
              href="/contacto"
              gradient="bg-gradient-to-br from-[#264e70]/10 to-[#679186]/15"
            />
          </div>

          <!-- WhatsApp Direct Card -->
          <div class="lg:col-4 col-6 mb-8">
            <NavigationCard
              iconName="whatsapp"
              title="WhatsApp Directo"
              description="Presupuesto gratuito en 5 minutos"
              href="https://wa.me/34640506084"
              external={true}
              gradient="bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/5"
              badge="🚨 GRATIS"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Stats Section -->
    <section
      class="py-16 bg-gradient-to-r from-[#679186] to-[#264e70] text-white"
    >
      <div class="container">
        <div class="row text-center">
          <div class="lg:col-3 col-6 mb-8">
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">500+</div>
              <div class="text-white/80">Mudanzas Realizadas</div>
            </div>
          </div>
          <div class="lg:col-3 col-6 mb-8">
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">10+</div>
              <div class="text-white/80">Años de Experiencia</div>
            </div>
          </div>
          <div class="lg:col-3 col-6 mb-8">
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">24/7</div>
              <div class="text-white/80">Atención al Cliente</div>
            </div>
          </div>
          <div class="lg:col-3 col-6 mb-8">
            <div class="text-center">
              <div class="text-4xl font-bold mb-2">98%</div>
              <div class="text-white/80">Clientes Satisfechos</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
