---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import NavigationCard from "../components/ui/NavigationCard.astro";

const title = "Mudanzas profesionales en Barcelona y España | Mudanzas ANDY";
const description =
  "Mudanzas profesionales en Barcelona y toda España. Presupuesto GRATIS en 5 minutos por WhatsApp. Atención 24/7. ¡Tu mudanza, nuestra prioridad!";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Hero Section -->
    <HeroSection />

    <!-- Navigation Cards Section -->
    <section class="section-spacing relative overflow-hidden">
      <!-- Background with enhanced gradients -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-accent/5"
      >
      </div>

      <!-- Decorative elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-10 right-20 w-24 h-24 bg-gradient-to-br from-secondary to-accent rounded-full blur-2xl"
        >
        </div>
        <div
          class="absolute bottom-10 left-20 w-32 h-32 bg-gradient-to-br from-[#fdebd3] to-neutral rounded-full blur-2xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center mb-16 lg:mb-20">
          <div class="lg:col-10">
            <div
              class="inline-flex items-center gap-2 bg-gradient-to-r from-accent/20 to-secondary/20 px-4 py-2 rounded-full mb-6"
            >
              <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"
              ></span>
              <span
                class="text-secondary font-semibold text-sm uppercase tracking-wide"
                >Navega por Nuestros Servicios</span
              >
            </div>

            <h2
              class="text-3xl lg:text-4xl font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent mb-4"
            >
              Descubre Nuestros Servicios
            </h2>
            <p class="text-gray-600 text-lg lg:text-xl max-w-3xl mx-auto">
              Explora todo lo que ofrecemos para hacer de tu mudanza una
              <strong class="text-secondary">experiencia perfecta</strong> y sin
              preocupaciones
            </p>
          </div>
        </div>

        <!-- Enhanced navigation grid with perfect centering -->
        <div class="nav-grid-center max-w-6xl mx-auto">
          <!-- Services Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="package"
              title="Servicios"
              description="Mudanzas locales, nacionales, internacionales y más"
              href="/servicios"
              gradient="bg-gradient-to-br from-accent/15 to-[#fdebd3]/25"
              badge="⭐ POPULAR"
            />
          </div>

          <!-- Team Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="truck"
              title="Nuestro Equipo"
              description="Profesionales experimentados y comprometidos"
              href="/equipo"
              gradient="bg-gradient-to-br from-secondary/15 to-neutral/25"
            />
          </div>

          <!-- Pricing Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="archive"
              title="Precios"
              description="Tarifas transparentes y presupuesto gratuito"
              href="/precios"
              gradient="bg-gradient-to-br from-[#fdebd3]/25 to-accent/15"
            />
          </div>

          <!-- Testimonials Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="check"
              title="Testimonios"
              description="Experiencias reales de clientes satisfechos"
              href="/testimonios"
              gradient="bg-gradient-to-br from-neutral/25 to-secondary/15"
            />
          </div>

          <!-- Contact Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="phone"
              title="Contacto"
              description="Hablemos de tu mudanza. Atención 24/7"
              href="/contacto"
              gradient="bg-gradient-to-br from-primary/15 to-secondary/20"
            />
          </div>

          <!-- WhatsApp Direct Card -->
          <div
            class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]"
          >
            <NavigationCard
              iconName="whatsapp"
              title="WhatsApp Directo"
              description="Presupuesto gratuito en 5 minutos"
              href="https://wa.me/34640506084"
              external={true}
              gradient="bg-gradient-to-br from-[#25D366]/15 to-[#128C7E]/10"
              badge="🚨 GRATIS"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Stats Section -->
    <section
      class="section-spacing-loose bg-gradient-to-r from-secondary to-primary text-white relative overflow-hidden"
    >
      <!-- Enhanced background patterns -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-0 left-0 w-full h-full"
          style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 40px 40px;"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <!-- Enhanced stats grid with perfect centering -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
          <div class="text-center">
            <div class="text-4xl lg:text-5xl font-bold mb-3 text-white">
              500+
            </div>
            <div class="text-white/90 font-medium">Mudanzas Realizadas</div>
          </div>
          <div class="text-center">
            <div class="text-4xl lg:text-5xl font-bold mb-3 text-white">
              10+
            </div>
            <div class="text-white/90 font-medium">Años de Experiencia</div>
          </div>
          <div class="text-center">
            <div class="text-4xl lg:text-5xl font-bold mb-3 text-white">
              24/7
            </div>
            <div class="text-white/90 font-medium">Atención al Cliente</div>
          </div>
          <div class="text-center">
            <div class="text-4xl lg:text-5xl font-bold mb-3 text-white">
              98%
            </div>
            <div class="text-white/90 font-medium">Clientes Satisfechos</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
