---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TeamSection from "../components/sections/TeamSection.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";

const title = "Nuestro Equipo Profesional | Mudanzas ANDY";
const description =
  "Conoce al equipo de profesionales de Mudanzas ANDY. Experiencia, dedicación y compromiso en cada mudanza. Más de 10 años de experiencia.";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Nuestro Equipo" },
];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="bg-gradient-to-b from-[#679186] to-[#264e70] py-8">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">
              Nuestro Equipo
            </h1>
            <p class="text-white/90 text-lg max-w-2xl">
              Profesionales experimentados comprometidos con la excelencia. Tu
              mudanza en las mejores manos.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Content -->
    <TeamSection />

    <!-- Values Section -->
    <section class="py-16 bg-gray-50">
      <div class="container">
        <div class="row justify-center text-center mb-12">
          <div class="lg:col-8">
            <h2 class="text-3xl font-bold text-[#264e70] mb-4">
              Nuestros Valores
            </h2>
            <p class="text-gray-600 text-lg">
              Lo que nos diferencia como equipo profesional
            </p>
          </div>
        </div>

        <div class="row">
          <div class="lg:col-4 mb-8">
            <div class="text-center p-6">
              <div
                class="w-16 h-16 bg-[#679186] rounded-full flex items-center justify-center mx-auto mb-4"
              >
                <span class="text-2xl">🎯</span>
              </div>
              <h3 class="text-xl font-semibold text-[#264e70] mb-3">
                Precisión
              </h3>
              <p class="text-gray-600">
                Cada mudanza se planifica al detalle para garantizar un traslado
                perfecto y sin contratiempos.
              </p>
            </div>
          </div>

          <div class="lg:col-4 mb-8">
            <div class="text-center p-6">
              <div
                class="w-16 h-16 bg-[#679186] rounded-full flex items-center justify-center mx-auto mb-4"
              >
                <span class="text-2xl">🤝</span>
              </div>
              <h3 class="text-xl font-semibold text-[#264e70] mb-3">
                Confianza
              </h3>
              <p class="text-gray-600">
                Tu tranquilidad es nuestra prioridad. Cuidamos tus pertenencias
                como si fueran nuestras.
              </p>
            </div>
          </div>

          <div class="lg:col-4 mb-8">
            <div class="text-center p-6">
              <div
                class="w-16 h-16 bg-[#679186] rounded-full flex items-center justify-center mx-auto mb-4"
              >
                <span class="text-2xl">⚡</span>
              </div>
              <h3 class="text-xl font-semibold text-[#264e70] mb-3">
                Eficiencia
              </h3>
              <p class="text-gray-600">
                Optimizamos tiempo y recursos para ofrecerte el mejor servicio
                al mejor precio.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
