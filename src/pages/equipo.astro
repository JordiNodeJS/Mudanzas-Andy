---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TeamSection from "../components/sections/TeamSection.astro";
import ValueCard from "../components/ui/ValueCard.astro";
import Icon from "../components/ui/Icon.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";

const title = "Nuestro Equipo Profesional | Mudanzas ANDY";
const description =
  "Conoce al equipo de profesionales de Mudanzas ANDY. Experiencia, dedicación y compromiso en cada mudanza. Más de 10 años de experiencia.";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Nuestro Equipo" },
];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="py-16 lg:py-20 relative overflow-hidden">
      <!-- Background with patterns and gradients -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-[#679186] via-[#264e70] to-[#679186]"
      >
      </div>

      <!-- Decorative background elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-20 right-10 w-32 h-32 bg-gradient-to-br from-[#f9b4ab] to-white rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-20 left-10 w-48 h-48 bg-gradient-to-br from-white to-[#fdebd3] rounded-full blur-3xl"
        >
        </div>
      </div>

      <!-- Background truck image -->
      <div class="absolute inset-0 opacity-5">
        <img
          src="/camion/hero-fondo.jpg"
          alt="Fondo: Equipo profesional de mudanzas"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center">
          <div class="lg:col-10">
            <!-- Badge -->
            <div
              class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-6"
            >
              <span class="w-2 h-2 bg-[#f9b4ab] rounded-full animate-pulse"
              ></span>
              <span
                class="text-white font-semibold text-sm uppercase tracking-wide"
                >Equipo Profesional</span
              >
            </div>

            <h1
              class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6"
            >
              🚛 Nuestro Equipo Experto
            </h1>
            <p class="text-white/90 text-lg lg:text-xl max-w-3xl mx-auto mb-8">
              <strong>Más de 14 años de experiencia</strong> respaldando cada mudanza.
              Profesionales comprometidos con la <strong
                >excelencia y tu tranquilidad</strong
              >.
            </p>

            <!-- Stats -->
            <div
              class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto"
            >
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-bold text-white mb-1">
                  +500
                </div>
                <div class="text-white/80 text-sm">Mudanzas Exitosas</div>
              </div>
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-bold text-white mb-1">
                  14+
                </div>
                <div class="text-white/80 text-sm">Años Experiencia</div>
              </div>
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-bold text-white mb-1">
                  98%
                </div>
                <div class="text-white/80 text-sm">Clientes Satisfechos</div>
              </div>
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
                <div class="text-2xl lg:text-3xl font-bold text-white mb-1">
                  24/7
                </div>
                <div class="text-white/80 text-sm">Disponibilidad</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Content -->
    <TeamSection />

    <!-- Values Section -->
    <section class="py-16 lg:py-20 relative overflow-hidden">
      <!-- Background -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-[#f9b4ab]/5"
      >
      </div>

      <!-- Decorative elements -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-br from-[#679186] to-[#f9b4ab] rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-20 right-10 w-48 h-48 bg-gradient-to-br from-[#fdebd3] to-[#bbd4ce] rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="container relative z-10">
        <div class="row justify-center text-center mb-12 lg:mb-16">
          <div class="lg:col-10">
            <div
              class="inline-flex items-center gap-2 bg-gradient-to-r from-[#f9b4ab]/20 to-[#679186]/20 px-4 py-2 rounded-full mb-6"
            >
              <span class="w-2 h-2 bg-[#679186] rounded-full animate-pulse"
              ></span>
              <span
                class="text-[#679186] font-semibold text-sm uppercase tracking-wide"
                >Lo Que Nos Diferencia</span
              >
            </div>

            <h2
              class="text-3xl lg:text-4xl font-bold bg-gradient-to-r from-[#264e70] to-[#679186] bg-clip-text text-transparent mb-6"
            >
              Nuestros Valores Fundamentales
            </h2>
            <p class="text-gray-600 text-lg lg:text-xl max-w-3xl mx-auto">
              Estos son los pilares que nos convierten en <strong
                class="text-[#679186]">el equipo de mudanzas</strong
              >
              más confiable de Barcelona y España.
            </p>
          </div>
        </div>

        <!-- Values Grid - Asymmetric Layout -->
        <div class="row">
          <!-- Large featured card -->
          <div class="lg:col-6 mb-8">
            <ValueCard
              iconName="bolt"
              title="Precisión Milimétrica"
              description="Cada mudanza se planifica al detalle para garantizar un traslado perfecto y sin contratiempos. Cronogramas exactos, coordinación impecable y ejecución profesional en cada paso."
              gradient="bg-gradient-to-br from-[#f9b4ab]/15 to-[#fdebd3]/25"
              size="large"
              stats="99.8%"
              highlight="Tasa de Éxito"
              badge="Garantizado"
              featured={true}
              animationDelay={0}
            />
          </div>

          <!-- Two medium cards -->
          <div class="lg:col-6">
            <div class="row">
              <div class="lg:col-12 mb-4">
                <ValueCard
                  iconName="check"
                  title="Confianza Absoluta"
                  description="Tu tranquilidad es nuestra prioridad. Cuidamos tus pertenencias como si fueran nuestras, con el máximo respeto y dedicación profesional."
                  gradient="bg-gradient-to-br from-[#679186]/15 to-[#bbd4ce]/25"
                  size="medium"
                  stats="14+ años"
                  highlight="Experiencia"
                  animationDelay={100}
                />
              </div>
              <div class="lg:col-12 mb-4">
                <ValueCard
                  iconName="truck"
                  title="Eficiencia Superior"
                  description="Optimizamos tiempo y recursos para ofrecerte el mejor servicio al mejor precio. Tecnología y experiencia al servicio de tu mudanza."
                  gradient="bg-gradient-to-br from-[#264e70]/15 to-[#679186]/20"
                  size="medium"
                  stats="+500"
                  highlight="Mudanzas"
                  animationDelay={200}
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Second row - Three columns with different sizes -->
        <div class="row mt-8">
          <div class="lg:col-4 mb-8">
            <ValueCard
              iconName="archive"
              title="Compromiso Total"
              description="No descansamos hasta que tu mudanza sea perfecta. Seguimiento personalizado desde el primer contacto hasta la entrega final."
              gradient="bg-gradient-to-br from-[#fdebd3]/25 to-[#f9b4ab]/15"
              size="medium"
              badge="24/7"
              animationDelay={300}
            />
          </div>

          <div class="lg:col-4 mb-8">
            <ValueCard
              iconName="globe"
              title="Transparencia Completa"
              description="Sin letra pequeña ni sorpresas. Presupuestos claros, comunicación directa y honestidad en cada paso del proceso."
              gradient="bg-gradient-to-br from-[#bbd4ce]/25 to-[#679186]/15"
              size="medium"
              stats="100%"
              highlight="Transparencia"
              animationDelay={400}
            />
          </div>

          <div class="lg:col-4 mb-8">
            <ValueCard
              iconName="tools"
              title="Equipamiento Profesional"
              description="Herramientas especializadas y vehículos modernos para garantizar la máxima protección de tus pertenencias."
              gradient="bg-gradient-to-br from-[#f9b4ab]/10 to-[#fdebd3]/20"
              size="medium"
              badge="Certificado"
              animationDelay={500}
            />
          </div>
        </div>

        <!-- Final row - Achievement cards -->
        <div class="row mt-12">
          <div class="lg:col-12">
            <div
              class="bg-gradient-to-r from-[#264e70]/5 via-[#679186]/5 to-[#f9b4ab]/5 rounded-2xl p-8 border border-[#679186]/20"
            >
              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-[#264e70] mb-4">
                  Nuestro Compromiso Contigo
                </h3>
                <p class="text-gray-600 max-w-2xl mx-auto">
                  Más que una empresa de mudanzas, somos tu socio de confianza
                  para uno de los momentos más importantes de tu vida.
                </p>
              </div>

              <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="text-center">
                  <div
                    class="w-16 h-16 bg-gradient-to-br from-[#679186] to-[#f9b4ab] rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg"
                  >
                    <Icon name="check" class="text-white" size={24} />
                  </div>
                  <div class="text-lg font-bold text-[#264e70]">98%</div>
                  <div class="text-sm text-gray-600">Satisfacción</div>
                </div>

                <div class="text-center">
                  <div
                    class="w-16 h-16 bg-gradient-to-br from-[#f9b4ab] to-[#fdebd3] rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg"
                  >
                    <Icon name="clock" class="text-[#264e70]" size={24} />
                  </div>
                  <div class="text-lg font-bold text-[#264e70]">24h</div>
                  <div class="text-sm text-gray-600">Respuesta</div>
                </div>

                <div class="text-center">
                  <div
                    class="w-16 h-16 bg-gradient-to-br from-[#bbd4ce] to-[#679186] rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg"
                  >
                    <Icon name="users" class="text-white" size={24} />
                  </div>
                  <div class="text-lg font-bold text-[#264e70]">5</div>
                  <div class="text-sm text-gray-600">Especialistas</div>
                </div>

                <div class="text-center">
                  <div
                    class="w-16 h-16 bg-gradient-to-br from-[#264e70] to-[#679186] rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg"
                  >
                    <Icon name="star" class="text-white" size={24} />
                  </div>
                  <div class="text-lg font-bold text-[#264e70]">5★</div>
                  <div class="text-sm text-gray-600">Valoración</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
