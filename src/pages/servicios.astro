---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ServicesSection from "../components/sections/ServicesSection.astro";
import Breadcrumb from "../components/ui/Breadcrumb.astro";

const title = "Servicios de Mudanzas Profesionales | Mudanzas ANDY";
const description =
  "Descubre todos nuestros servicios de mudanzas: locales, nacionales, internacionales, embalaje profesional y más. Atención 24/7 en Barcelona y España.";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios" },
];
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <section class="bg-gradient-to-b from-secondary to-primary py-8">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h1 class="text-3xl lg:text-4xl font-bold text-white mb-4">
              Nuestros Servicios
            </h1>
            <p class="text-white/90 text-lg max-w-2xl">
              Mudanzas profesionales adaptadas a tus necesidades. Desde mudanzas
              locales hasta traslados internacionales.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Content -->
    <ServicesSection />

    <!-- Call to Action -->
    <section class="bg-gradient-to-r from-secondary to-primary py-16">
      <div class="container">
        <div class="row justify-center text-center">
          <div class="lg:col-8">
            <h2 class="text-3xl font-bold text-white mb-4">
              ¿Necesitas más información?
            </h2>
            <p class="text-white/90 text-lg mb-8">
              Contáctanos ahora y recibe tu presupuesto gratuito en 5 minutos
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="tel:+34123456789"
                class="bg-white text-primary px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-all transform hover:scale-105"
              >
                📞 Llamar Ahora
              </a>
              <a
                href="https://wa.me/34123456789"
                class="bg-green-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-green-600 transition-all transform hover:scale-105"
                target="_blank"
                rel="noopener noreferrer"
              >
                💬 WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
