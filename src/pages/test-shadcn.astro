---
import Layout from "../layouts/Layout.astro";
import { ButtonShadcn } from "../components/ButtonShadcn";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
import ButtonHybrid from "../components/ButtonHybrid.astro";
---

<Layout>
  <main class="container mx-auto p-8">
    <h1 class="text-3xl font-bold mb-8">shadcn/ui Integration Test</h1>

    <div class="space-y-6">
      <!-- Test React Button with hydration -->
      <section>
        <h2 class="text-xl font-semibold mb-4">
          React Button Component (shadcn/ui)
        </h2>
        <div class="flex gap-4">
          <ButtonShadcn client:load variant="default"
            >Default Button</ButtonShadcn
          >
          <ButtonShadcn client:load variant="outline"
            >Outline Button</ButtonShadcn
          >
          <ButtonShadcn client:load variant="secondary"
            >Secondary Button</ButtonShadcn
          >
          <ButtonShadcn client:load variant="destructive"
            >Destructive Button</ButtonShadcn
          >
        </div>
      </section>

      <!-- Test Hybrid Button Component -->
      <section>
        <h2 class="text-xl font-semibold mb-4">
          Hybrid Button Component (Migration Compatible)
        </h2>
        <div class="flex flex-wrap gap-4">
          <ButtonHybrid variant="primary" size="md">Primary Hybrid</ButtonHybrid
          >
          <ButtonHybrid variant="secondary" size="sm"
            >Secondary Small</ButtonHybrid
          >
          <ButtonHybrid variant="outline" size="lg">Outline Large</ButtonHybrid>
          <ButtonHybrid variant="destructive" client="load"
            >Destructive (load)</ButtonHybrid
          >
          <ButtonHybrid variant="ghost" fullWidth={false}
            >Ghost Button</ButtonHybrid
          >
          <ButtonHybrid href="https://example.com" variant="link"
            >Link Button</ButtonHybrid
          >
        </div>
      </section>

      <!-- Test Card Component -->
      <section>
        <h2 class="text-xl font-semibold mb-4">Card Component (shadcn/ui)</h2>
        <Card client:load className="max-w-md">
          <CardHeader>
            <CardTitle>Test Card</CardTitle>
            <CardDescription
              >This is a test card to verify shadcn/ui integration</CardDescription
            >
          </CardHeader>
          <CardContent>
            <p>
              Card content goes here. This demonstrates that the Card component
              is working properly.
            </p>
            <div class="mt-4">
              <ButtonHybrid variant="primary" size="sm"
                >Card Action</ButtonHybrid
              >
            </div>
          </CardContent>
        </Card>
      </section>

      <!-- Compare with existing Astro Button -->
      <section>
        <h2 class="text-xl font-semibold mb-4">Migration Comparison</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <h3 class="font-medium mb-2">shadcn/ui Button (React)</h3>
            <ButtonShadcn client:load variant="default"
              >shadcn Button</ButtonShadcn
            >
          </div>
          <div>
            <h3 class="font-medium mb-2">Hybrid Button (Migration)</h3>
            <ButtonHybrid variant="primary">Hybrid Button</ButtonHybrid>
          </div>
          <div>
            <h3 class="font-medium mb-2">Original Astro Button</h3>
            <button
              class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-base bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500 shadow-sm"
            >
              Astro Button
            </button>
          </div>
        </div>
      </section>

      <!-- Migration Benefits -->
      <section>
        <h2 class="text-xl font-semibold mb-4">Migration Benefits</h2>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <h3 class="font-medium text-green-800 mb-2">
            ✅ Migration Advantages:
          </h3>
          <ul class="text-green-700 space-y-1">
            <li>• Consistent design system with CSS variables</li>
            <li>• Better accessibility with Radix UI primitives</li>
            <li>• Type-safe props with TypeScript</li>
            <li>• Gradual migration path - no breaking changes</li>
            <li>• Backward compatibility with existing Astro components</li>
            <li>• Modern React patterns with minimal hydration</li>
          </ul>
        </div>
      </section>
    </div>
  </main>
</Layout>
